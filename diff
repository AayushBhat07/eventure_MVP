+import { mutation } from "./_generated/server";
+import { v } from "convex/values";
+import { internal } from "./_generated/api";
+import bcrypt from "bcryptjs";
+import { ROLES } from "./schema";
+
+export const createAdminUserForTesting = mutation({
+  args: {
+    email: v.string(),
+    password: v.string(),
+  },
+  handler: async (ctx, args) => {
+    const hashedPassword = await bcrypt.hash(args.password, 10);
+    try {
+      const result = await ctx.runMutation(internal.admin_creation.createAdminInternal, {
+        email: args.email,
+        passwordHash: hashedPassword,
+        role: ROLES.ADMIN,
+      });
+      return { success: true, message: result.message, id: result.id };
+    } catch (error) {
+      return { success: false, message: error instanceof Error ? error.message : "Failed to create admin user." };
+    }
+  },
+});
